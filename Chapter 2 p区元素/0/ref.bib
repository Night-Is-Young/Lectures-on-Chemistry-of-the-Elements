@article{GRAHAM2000321,
    title = {Concerning the nature of XePtF6},
    journal = {Coordination Chemistry Reviews},
    volume = {197},
    number = {1},
    pages = {321-334},
    year = {2000},
    issn = {0010-8545},
    doi = {https://doi.org/10.1016/S0010-8545(99)00190-3},
    url = {https://www.sciencedirect.com/science/article/pii/S0010854599001903},
    author = {Lionell Graham and Oliver Graudejus and Narendra K. Jha and Neil Bartlett},
    keywords = {XePtF, Diamagnetic, X-ray powder diffraction pattern},
    abstract = {Interaction of PtF6 vapor with a comparable molar quantity of Xe gas, at ≈ 20°C, gives a sticky, red-tinged yellow solid of composition Xe(PtF6)x, with 1≤x≤2, X-ray powder diffraction pattern (XRDP) of which show the presence of XeF+PtF6− {a=8.081(6); b=11.087(7); c=7.226(6) Å; β=90.01(5)°; VlZ =161.8(4) Å3} which is isostructural with XeF+RuF6−. This implies that first formed XePtF6+PtF6→XeF+PtF6−+PtF5 (non-crystalline). When the product having x ≈ 2 is warmed (≤60°C) it is converted to the orange–red, friable solid XeF+Pt2F11−: XeF+PtF6−+PtF5→XeF+Pt2F11−. Mixing PtF6 vapor (diluted with SF6 gas), with a large excess of Xe gas, with the product mixture quenched at 77 K, gives a mustard yellow solid of composition ≈ XePtF6. This does not give an XRDP, and is only weakly paramagnetic. Dissolution of PtF4, with a large excess of XeF2 in aHF gives a yellow solution, the 19F NMR spectrum of which reveals PtF62−. The diamagnetic, amorphous, aHF-insoluble solid, of composition ≈ XePtF6 obtained from that solution is probably a XeF+ salt of polymeric (PtF5−)n. The 1:1 product of Xe+PtF6 is also likely to be of this formulation.}
}
@article{Stefano2024,
    author = {Borocci, Stefano and Grandinetti, Felice and Sanna, Nico and Zazza, Costantino},
    title = {Noble Gas Anions: An Overview of Strategies and Bonding Motifs},
    journal = {Chemistry – An Asian Journal},
    volume = {19},
    number = {14},
    pages = {e202400191},
    keywords = {gas-phase chemistry, high-pressure chemistry, noble gas anions, synthetic chemistry, theoretical calculations},
    doi = {https://doi.org/10.1002/asia.202400191},
    url = {https://aces.onlinelibrary.wiley.com/doi/abs/10.1002/asia.202400191},
    eprint = {https://aces.onlinelibrary.wiley.com/doi/pdf/10.1002/asia.202400191},
    abstract = {Abstract This review article aims to provide an overview of the strategies employed to prepare noble gas anions under different environments and experimental conditions, and of the bonding motifs typically occurring in these species. Observed systems include anions fixed into synthesized salts, detected in the gas phase or in high-pressure devices. The major role of the theoretical calculations is also highlighted, not only in support of the experiments, but also as effective in predicting still unreported species. The chemistry of noble gas anions overall appears as a varied and rich paint, offering fascinating opportunities for both experimentalists and theoreticians.},
    year = {2024}
}

